from packaging import version

f = open(workflow.source_path("../version.txt"))
__version__ = version.parse(f.read().strip())

print(f"\033[95mRunning MPRA QC analysis version {__version__.public}\033[0m")


include: "rules/common.smk"
include: "rules/variants.smk"
include: "rules/elements.smk"


print(f"\033[95mID:\033[92m {config['id']}\033[0m")


rule all_variants:
    input:
        expand(
            "results/{id}/reporter_variants/{id}.reporter_variants.{level}.tsv.gz",
            level=config["level"],
            id=config["id"],
        ),
        expand(
            "results/{id}/reporter_genomic_variants/{id}.reporter_genomic_variants.{level}.bed.gz",
            level=config["level"],
            id=config["id"],
        ),


rule all_elements:
    input:
        expand(
            "results/{id}/reporter_elements/{id}.reporter_elements.{level}.tsv.gz",
            level=config["level"],
            id=config["id"],
        ),
        expand(
            "results/{id}/reporter_genomic_elements/{id}.reporter_genomic_elements.{level}.bed.gz",
            level=config["level"],
            id=config["id"],
        ),
